{
    "latex-workshop.latex.recipes": [
        {
        "name": "latexmk (lualatex + glossaries)",
        "tools": ["latexmk-lualatex"]
        }
    ],
    "latex-workshop.latex.tools": [
        {
        "name": "latexmk-lualatex",
        "command": "latexmk",
        "args": [
            "-shell-escape",
            "-synctex=1",
            "-interaction=nonstopmode",
            "-file-line-error",
            "%DOC%"
        ],
        "env": {}
        }
    ],
    "cSpell.words": [
        "Autoencoders",
        "civilisational",
        "Interpretability",
        "Misgeneralisation",
        "monosemantic",
        "Polysemanticity",
        "satisficer",
        "Satisficers",
        "superintelligent",
        "underrepresentation",
        "Wireheading"
    ]
}